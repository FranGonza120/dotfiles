{
  "appearance": {
    "fontFamily": "JetBrainsMono Nerd Font"
  },
  "paths": {
    "pywalColors": "~/.cache/wal/colors.json"
  },
  "osd": {
    "volumeTimeoutMs": 2000,
    "brightnessTimeoutMs": 2000
  },
  "notifications": {
    "popupWidth": 340,
    "maxVisible": 5,
    "timeoutMs": 7000,
    "registerServer": true,
    "spacing": 10,
    "margin": 10
  },
  "launcher": {
    "enabled": true,
    "width": 720,
    "maxResults": 8,
    "terminalCommand": ["foot"],
    "favorites": [
      "app.zen_browser.zen",
      "thunar",
      "md.obsidian.Obsidian"
    ]
  }
}
