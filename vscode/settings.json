{
    // Default Settings
    "window.newWindowProfile": "Default",
    // Extensiones: Vim, fzf fuzzy quick open, plantUML, Tokyo Night, VSCode Harpoon, vsnetrw
    // Fuente
    "debug.console.fontSize": 16,
    "scm.inputFontSize": 16,
    "editor.fontSize": 16,
    "chat.fontFamily": "JetBrainsMono Nerd Font Mono",
    "editor.fontFamily": "JetBrainsMono Nerd Font Mono",
    "editor.fontLigatures": true,
    "scm.inputFontFamily": "JetBrainsMono Nerd Font Mono",
    "chat.editor.fontFamily": "JetBrainsMono Nerd Font Mono",
    "debug.console.fontFamily": "JetBrainsMono Nerd Font Mono",
    "notebook.markup.fontFamily": "JetBrainsMono Nerd Font Mono",
    "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font Mono",
    "notebook.output.fontFamily": "JetBrainsMono Nerd Font Mono",
    "editor.codeLensFontFamily": "JetBrainsMono Nerd Font Mono",
    "markdown.preview.fontFamily": "JetBrainsMono Nerd Font Mono",
    "editor.inlayHints.fontFamily": "JetBrainsMono Nerd Font Mono",
    "editor.inlineSuggest.fontFamily": "JetBrainsMono Nerd Font Mono",
    // Tema
    "workbench.colorTheme": "Tokyo Night",
    "workbench.colorCustomizations": {
      "[Tokyo Night]": {
        "sideBar.background": "#1a1b26",
        "statusBar.background": "#1a1b26",
        "titleBar.inactiveBackground": "#1a1b26",
        "titleBar.activeBackground": "#1a1b26",
      },
    },
    // GUI
    "workbench.editor.labelFormat": "medium",
    "breadcrumbs.enabled": false,
    "keyboard.dispatch": "keyCode",
    "editor.minimap.enabled": false,
    "workbench.activityBar.location": "hidden",
    "extensions.ignoreRecommendations": true,
    "chat.viewSessions.enabled": false,
    "chat.viewProgressBadge.enabled": false,
    "workbench.layoutControl.enabled": false,
    "workbench.navigationControl.enabled": false,
    "workbench.editor.editorActionsLocation": "hidden",
    "workbench.iconTheme": "material-icon-theme",
    "workbench.tips.enabled": false,
    "window.commandCenter": false,
    "window.controlsStyle": "hidden",
    "window.menuBarVisibility": "hidden",
    "window.titleBarStyle": "native",
    "material-icon-theme.hidesExplorerArrows": true,
    "workbench.startupEditor": "none",
    "workbench.tree.enableStickyScroll": false,
    "workbench.tree.renderIndentGuides": "none",
    "workbench.sideBar.location": "right",
    "workbench.tree.indent": 8,
    "explorer.compactFolders": false,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.decorations.badges": false,
    "git.decorations.enabled": false,
    "window.zoomLevel": 3,
    "editor.cursorBlinking": "solid",
    "editor.cursorStyle": "block",
    "editor.stickyScroll.enabled": false,
    "editor.codeLens": false,
    "editor.snippets.codeActions.enabled": false,
    "editor.matchBrackets": "never",
    "files.trimTrailingWhitespace": true,
    "scm.diffDecorations": "none",
    "editor.guides.indentation": false,
    "editor.scrollbar.horizontal": "hidden",
    "editor.scrollbar.vertical": "hidden",
    "editor.overviewRulerBorder": false,
    "editor.hideCursorInOverviewRuler": true,
    "editor.showFoldingControls": "never",
    "editor.renderLineHighlight": "none",
    "editor.occurrencesHighlight": "off",
    "editor.tabCompletion": "on",
    "editor.inlineSuggest.enabled": false,
    "editor.lightbulb.enabled": "off",
    "vscode_custom_css.statusbar": false,
    "vscode_custom_css.imports": [
      "file:///${userHome}/Escritorio/3.Recursos/dotfiles/vscode/vscode_css.css"
    ],
    // Configuraciones de la terminal
    "terminal.integrated.tabs.enabled": false,
    "terminal.integrated.defaultProfile.linux": "bash",
    "terminal.integrated.profiles.linux": {
        "bash": {
        "path": "/usr/bin/bash",
        "args": ["--login"]
        }
    },
    // Tab única
    "workbench.editor.limit.enabled": true,
    "workbench.editor.limit.perEditorGroup": true,
    "workbench.editor.limit.value": 1,
    "workbench.editor.showTabs": "single",
    "workbench.editor.enablePreview": true,
    "workbench.editor.enablePreviewFromQuickOpen": true,
    "workbench.editor.closeOnFileDelete": true,
    // Configuración de Extensión de vim
    "editor.lineNumbers": "relative",
    "vim.leader": "<Space>",
    "vim.hlsearch": true,
    "vim.incsearch": true,
    "vim.highlightedyank.enable": true,
    "vim.useSystemClipboard": true,
    "vim.autoindent": true,
    "vim.handleKeys": {
      "<Esc>": true,
    },
    // Harpoon
    "workbench.editor.revealIfOpen": true,
    // Nuevos?
}
